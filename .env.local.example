# GitHub OAuth - create at github.com/settings/applications/new
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Groq - free at console.groq.com
GROQ_API_KEY=
# Optional: second Groq key as fallback if the primary hits rate limits
GROQ_FALLBACK_API_KEY=

# Public app URL (used for OG meta tags) - set to your production URL before deploying
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: GitHub personal access token for unauthenticated API requests (avoids rate limits)
GITHUB_TOKEN=
